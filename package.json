{
  "name": "3drecon",
  "version": "1.0.0",
  "description": "Workspace scripts for the AI 3D reconstruction system.",
  "private": true,
  "scripts": {
    "server:dev": "python -m uvicorn server.main:app --host 0.0.0.0 --port 8000 --reload",
    "pipeline:3d": "cd project && python -m src.pipeline.sequential_3d_pipeline",
    "mobile": "npm --prefix mobile start",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:doctor": "npm --prefix mobile exec expo-doctor",
    "test": "python -m unittest discover -s project/tests -p \"test_*.py\" -v"
  }
}
